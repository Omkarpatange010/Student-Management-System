# Example environment configuration for Student Management System
# Copy this file to .env and fill in real values.

# MongoDB connection URI
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/student_management

# Server port
SERVER_PORT=8080

# Spring Security user (for emergency fallback)
SPRING_SECURITY_USER_NAME=omkarpatange77@gmail.com
SPRING_SECURITY_USER_PASSWORD=Omkar@3483
SPRING_SECURITY_USER_ROLES=ADMIN

# JWT / other secret keys (if used)
APP_JWT_SECRET=ChangeThisToAStrongRandomKey

# Optional: active Spring profile (dev/test/prod)
SPRING_PROFILES_ACTIVE=dev
